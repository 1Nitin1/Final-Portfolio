# API server
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Option A: use a single PostgreSQL URL
# Make sure special characters in password are URL encoded
# Example: @ -> %40
# DATABASE_URL=postgresql://postgres:password@localhost:5432/contactdb

# Option B: use separate DB fields
DB_HOST=localhost
DB_PORT=5432
DB_NAME=contactdb
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false

# Mail notifications (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM=your_email@gmail.com
MAIL_TO=nitinkumarbaranawal@gmail.com
