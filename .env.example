# API server
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Option A: use a single PostgreSQL URL
# Make sure special characters in password are URL encoded
# Example: @ -> %40
# DATABASE_URL=postgresql://postgres:password@localhost:5432/contactdb

# Option B: use separate DB fields
DB_HOST=localhost
DB_PORT=5432
DB_NAME=contactdb
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false
